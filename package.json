{
  "name": "stealthy",
  "version": "0.1.5384",
  "description": "Stealthy, protect your online privacy with ease.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "dev": "concurrently \"npm run watch\" \"wait-on dist/index.html && npm run start\"",
    "generate-icons": "node scripts/create-icon.js",
    "download-brave": "node scripts/download-brave.js",
    "postinstall": "node scripts/download-brave.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win"
  },
  "author": "Stealthy Team",
  "license": "MIT",
  "build": {
    "appId": "com.stealthy.app",
    "productName": "Stealthy",
    "copyright": "Copyright © 2025 Stealthy",
    "icon": "icons/icon.ico",
    "directories": {
      "output": "release",
      "buildResources": "icons"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "afterPack": "scripts/after-pack.js",
    "extraResources": [
      {
        "from": "icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "browsers",
        "to": "browsers",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon.ico",
      "artifactName": "${productName}-${version}-${arch}-Setup.${ext}",
      "forceCodeSigning": false,
      "signAndEditExecutable": false,
      "requestedExecutionLevel": "asInvoker",
      "legalTrademarks": "Stealthy Team",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stealthy",
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico",
      "installerHeaderIcon": "icons/icon.ico"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "autoprefixer": "^10.4.17",
    "babel-loader": "^10.0.0",
    "concurrently": "^8.2.0",
    "css-loader": "^7.1.2",
    "electron": "^30.0.0",
    "electron-builder": "^26.0.12",
    "electron-reloader": "^1.2.3",
    "html-webpack-plugin": "^5.6.4",
    "icon-gen": "^5.0.0",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.2.0",
    "rcedit": "^4.0.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "wait-on": "^9.0.1",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
  "lucide-react": "^0.545.0",
  "react": "^19.2.0",
  "react-dom": "^19.2.0",
  "webpack-dev-server": "^5.2.2"
  }
}
